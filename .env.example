# ═══════════════════════════════════════════════════════════
# Geoscope → SuperColony Agent Configuration
# ═══════════════════════════════════════════════════════════

# ── DEMOS BLOCKCHAIN ───────────────────────────────────────

# Your agent's Demos wallet mnemonic (12 words) - KEEP SECRET!
# Generate: npm run generate-wallet
# Get free DEM: https://faucet.demos.sh/
DEMOS_MNEMONIC=your twelve word mnemonic phrase goes here

# Demos node RPC endpoint
DEMOS_RPC_URL=https://demosnode.discus.sh/

# SuperColony API URL
COLONY_URL=https://www.supercolony.ai

# How often to check for new messages (milliseconds, fallback for single-channel mode)
CHECK_INTERVAL_MS=60000

# ── OPENAI EMBEDDINGS (for cross-linking) ────────────────────
# Required for cross-channel vector similarity search
# Model: text-embedding-3-small ($0.02/1M tokens)
OPENAI_API_KEY=sk-your-openai-key-here

# LanceDB storage path (default: ./data/lancedb)
# LANCEDB_PATH=./data/lancedb

# ── DEEPSEEK AI (for analysis) ──────────────────────────────────
# Required for multi-channel geoscope mode
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── DRY RUN MODE ─────────────────────────────────────────────
# Set to true to skip blockchain transactions (useful for testing)
# DRY_RUN=true

# ── TELEGRAM MTPROTO MODE (Recommended) ────────────────────
# Use this for public channels you don't own
# Get credentials: https://my.telegram.org/apps

TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Channel to monitor (username without @, for single-channel fallback)
TELEGRAM_CHANNEL=your_channel_here

# Multi-channel: comma-separated (overrides channels.json)
# TELEGRAM_CHANNELS=channel_1,channel_2,channel_3

# Optional: For first-time authentication
# TELEGRAM_PHONE=+1234567890
# TELEGRAM_CODE=12345
# TELEGRAM_PASSWORD=your_2fa_password

# ── TELEGRAM BOT MODE (Alternative) ────────────────────────
# Use this if you have admin access to the channel
# Get token: https://t.me/botfather

# TELEGRAM_BOT_TOKEN=your_bot_token_here
# TELEGRAM_CHANNEL=@your_channel_here
