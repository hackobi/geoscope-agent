# OpenAI API key for semantic search (text-embedding-3-small)
OPENAI_API_KEY=sk-your-openai-key-here

# Path to geoscope root (parent of cockpit/) — auto-detected if not set
# GEOSCOPE_ROOT=..

# Optional: API key for external search API access
# SEARCH_API_KEY=your-secret-key

# Optional: Restrict CORS origins (comma-separated, default: *)
# SEARCH_CORS_ORIGINS=https://yourdomain.com
